# ============================================================
# GOOGLE SHEETS - SERVICE ACCOUNT
# ============================================================

# Email de la Service Account (Google Cloud Console)
GOOGLE_SERVICE_ACCOUNT_EMAIL=mi-cuenta@mi-proyecto.iam.gserviceaccount.com

# Clave privada (del JSON descargado de Google Cloud)
# IMPORTANTE: mantener las comillas y los \n literales
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"

# ID del Google Spreadsheet
# Lo encuentras en la URL: docs.google.com/spreadsheets/d/ESTE_ES_EL_ID/edit
GOOGLE_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# ============================================================
# APP CONFIG (NEXT_PUBLIC_ = visible en el cliente)
# ============================================================

# Intervalo de polling en milisegundos (15000 = 15 segundos)
NEXT_PUBLIC_POLL_INTERVAL=15000

# Título que aparece en la UI y en el tab del navegador
NEXT_PUBLIC_APP_TITLE="Mi Dashboard"

# Nombre de la hoja principal a mostrar en el dashboard
NEXT_PUBLIC_DEFAULT_SHEET=Sheet1
